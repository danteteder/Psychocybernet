# Psychocybernet - Local Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── Supabase (Required) ──
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Hermes AI Gateway (Optional) ──
# Default: http://100.108.28.43:8080 (Tailscale IP)
# Change this to your Hermes instance URL
# Can be localhost for development, Tailscale IP, or public URL
NEXT_PUBLIC_HERMES_URL=http://100.108.28.43:8080

# ── Webhook Configuration (Server-side only) ──
# Base URL for outgoing webhooks from Hermes to Psychocybernet
HERMES_WEBHOOK_BASE=https://your-domain.vercel.app/api/webhooks

# Webhook secret for signature verification (generate a random string)
HERMES_WEBHOOK_SECRET=your-webhook-secret-here

# ── Optional Integrations ──
# These can also be configured via Settings UI
# INSTANTLY_API_KEY=your-instantly-api-key
# SHOPIFY_STORE_URL=your-store.myshopify.com
# BROWSERBASE_API_KEY=your-browserbase-key
